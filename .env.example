# Application runtime configuration loaded from the project root.
HOST=127.0.0.1
PORT=3000
SERVER_TYPE=http
ALARISA_DATA_ROOT=var

# WebAuthn relying-party and comfortable development defaults.
ALARISA_AUTH_ORIGIN=http://localhost:3000
ALARISA_AUTH_RP_ID=localhost
ALARISA_AUTH_RP_NAME=Alarisa
ALARISA_AUTH_CHALLENGE_MINUTES=5
ALARISA_AUTH_ENROLLMENT_MINUTES=15
ALARISA_AUTH_MOB_SESSION_DAYS=90
ALARISA_AUTH_DESK_SESSION_DAYS=180
ALARISA_AUTH_STEP_UP_MINUTES=30
